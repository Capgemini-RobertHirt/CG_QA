  "design": {
    "fonts": {
      "title": {
        "allowed": [
          "Calibri",
          "Segoe UI"
        ],
        "size": {
          "min": 20,
          "max": 28
        },
        "weight": "bold"
      },
      "heading": {
        "allowed": [
          "Calibri",
          "Segoe UI"
        ],
        "size": {
          "min": 14,
          "max": 18
        },
        "weight": [
          "bold",
          "semibold"
        ]
      },
      "body": {
        "allowed": [
          "Calibri",
          "Segoe UI"
        ],
        "size": {
          "min": 10,
          "max": 12
        },
        "weight": "regular"
      }
    },
    "colors": {
      "palette_required": true,
      "primary": [
        "#003366",
        "#0066CC"
      ],
      "secondary": [
        "#FFFFFF",
        "#F5F5F5"
      ],
      "text": [
        "#000000",
        "#1F1F1F"
      ],
      "accent": [
        "#FF6B35"
      ],
      "max_colors_per_page": 5
    },
    "grid": {
      "type": "column_grid",
      "columns": 12,
      "gutter": 0.25,
      "baseline_grid": true,
      "snap_tolerance_px": 4
    },
    "alignment": {
      "enforce_horizontal": true,
      "enforce_vertical": true,
      "justification_allowed": [
        "left"
      ],
      "nearly_aligned_threshold_px": 6
    },
    "spacing": {
      "line_spacing": {
        "min": 1.1,
        "max": 1.2
      },
      "paragraph_spacing_px": {
        "before": 6,
        "after": 6
      },
      "consistent_spacing_required": true
    },
    "master_usage": {
      "required": true,
      "allow_local_overrides": false
    }
  },
  "components": {
    "repeated_components": {
      "insight_callout": {
        "required_alignment": {
          "image_anchor": "left",
          "text_anchor": "left",
          "consistent_across_document": true
        }
      }
    }
  },
  "images": {
    "min_resolution_dpi": 150,
    "max_width_percent": 90,
    "captions": {
      "required": true,
      "position": "below"
    },
    "alignment_to_grid_required": true
  },
  "tables": {
    "header_required": true,
    "header_style": "bold",
    "border_style": "light_grid",
    "row_alignment_consistent": true
  },
  "header_footer": {
    "required": true,
    "locked": true,
    "footer_contains": [
      "page_number",
      "company_name",
      "date"
    ],
    "date_required": true
  },
  "compliance": {
    "legal_disclaimer": {
      "required": false,
      "position": "front",
      "non_editable_text": true
    },
    "ip_usage": {
      "logo_sources_whitelisted": true,
      "third_party_logos_disallowed": true
    },
    "confidentiality_level": {
      "allowed": [
        "company_confidential",
        "public"
      ],
      "must_match_document_type": false
    }
  },
  "business_context": {
    "client_specificity": {
      "client_name_required": false,
      "industry_context_required": true,
      "generic_phrases_penalized": true
    },
    "governance_clarity": {
      "roles_named": false,
      "decision_authority_explicit": false
    },
    "value_logic": {
      "objectives_linked_to_outcomes": true,
      "metrics_defined": true
    },
    "consistency_checks": {
      "terminology_consistent": true,
      "numbers_consistent_across_sections": true
    }
  },
  "anti_patterns": {
    "design": [
      "almost_aligned_elements",
      "inconsistent_component_variants",
      "drifting_margins",
      "manual_font_overrides"
    ],
    "content": [
      "lack_of_differentiation",
      "missing_strategic_perspective",
      "vague_recommendations",
      "weak_call_to_action"
    ]
  },
  "output": {
    "per_dimension_scores": true,
    "annotated_findings": true,
    "heatmap_support": true,
    "explainability_required": true
  }
}