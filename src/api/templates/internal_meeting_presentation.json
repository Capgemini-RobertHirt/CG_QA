  "global_rules": {
    "severity_levels": [
      "blocker",
      "critical",
      "major",
      "minor",
      "advisory"
    ],
    "scoring": {
      "weights": {
        "structure": 0.3,
        "design": 0.3,
        "compliance": 0.15,
        "business_context": 0.25
      }
    }
  },
  "structure": {
    "sections": {
      "required": [
        "title_slide",
        "meeting_agenda",
        "executive_summary",
        "background_context",
        "key_topics",
        "discussion_points",
        "action_items",
        "next_steps"
      ],
      "optional": [
        "appendix",
        "references",
        "glossary",
        "contact_information"
      ],
      "ordering_enforced": true,
      "page_break_after": [
        "executive_summary",
        "discussion_points"
      ]
    },
    "toc": {
