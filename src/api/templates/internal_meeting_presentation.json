  "design": {
    "fonts": {
      "title": {
        "allowed": [
          "Calibri",
          "Segoe UI"
        ],
        "size": {
          "min": 28,
          "max": 44
        },
        "weight": "bold"
      },
      "heading": {
        "allowed": [
          "Calibri",
          "Segoe UI"
        ],
        "size": {
          "min": 18,
          "max": 24
        },
        "weight": [
          "bold",
          "semibold"
        ]
      },
      "body": {
        "allowed": [
          "Calibri",
          "Segoe UI"
        ],
        "size": {
          "min": 12,
          "max": 14
        },
        "weight": "regular"
      }
    },
    "colors": {
      "palette_required": true,
      "primary": [
        "#003366",
        "#0066CC"
      ],
      "secondary": [
        "#FFFFFF",
        "#F5F5F5"
      ],
      "text": [
        "#000000",
        "#1F1F1F"
      ],
      "accent": [
        "#FF6B35"
      ],
      "max_colors_per_page": 5
    },
    "grid": {
      "type": "column_grid",
      "columns": 12,
      "gutter": 0.25,
      "baseline_grid": true,
      "snap_tolerance_px": 4
    },
    "alignment": {
      "enforce_horizontal": true,
      "enforce_vertical": true,
      "justification_allowed": [
        "left",
        "center"
      ],
      "nearly_aligned_threshold_px": 6
    },
    "spacing": {
      "line_spacing": {
        "min": 1.2,
        "max": 1.5
      },
      "paragraph_spacing_px": {
        "before": 8,
        "after": 8
      },
      "consistent_spacing_required": true
    },
    "master_usage": {
      "required": true,
      "allow_local_overrides": false
    }
  },
  "components": {
    "repeated_components": {
      "agenda_item": {
        "required_alignment": {
          "time_anchor": "left",
          "topic_anchor": "left",
          "consistent_across_document": true
        }
      },
      "action_item_box": {
        "required_alignment": {
          "owner_anchor": "left",
          "deadline_anchor": "right",
          "consistent_across_document": true
        }
      }
    }
  },
  "images": {
    "min_resolution_dpi": 120,
    "max_width_percent": 85,
    "captions": {
      "required": false,
      "position": "below"
    },
    "alignment_to_grid_required": true
  },
  "tables": {
    "header_required": true,
    "header_style": "bold",
    "border_style": "light_grid",
    "row_alignment_consistent": true
  },
  "header_footer": {
    "required": true,
    "locked": true,
    "footer_contains": [
      "slide_number",
      "company_name",
      "meeting_date"
    ],
    "date_required": true
  },
  "compliance": {
    "legal_disclaimer": {
      "required": false,
      "position": "back",
      "non_editable_text": true
    },
    "ip_usage": {
      "logo_sources_whitelisted": true,
      "third_party_logos_disallowed": true
    },
    "confidentiality_level": {
      "allowed": [
        "internal_only",
        "company_confidential"
      ],
      "must_match_document_type": false
    }
  },
  "business_context": {
    "client_specificity": {
      "client_name_required": false,
      "industry_context_required": false,
      "generic_phrases_penalized": false
    },
    "governance_clarity": {
      "roles_named": true,
      "decision_authority_explicit": true
    },
    "value_logic": {
      "objectives_linked_to_outcomes": true,
      "metrics_defined": true
    },
    "consistency_checks": {
      "terminology_consistent": true,
      "numbers_consistent_across_sections": true
    }
  },
  "anti_patterns": {
    "design": [
      "overcrowded_slides",
      "inconsistent_component_variants",
      "poor_readability",
      "manual_font_overrides"
    ],
    "content": [
      "unclear_action_items",
      "missing_owners",
      "vague_next_steps",
      "no_time_allocations"
    ]
  },
  "output": {
    "per_dimension_scores": true,
    "annotated_findings": true,
    "heatmap_support": true,
    "explainability_required": true
  }
}